# 项目运行时数据（缓存 + 会话记忆），不入版本控制
.agent-cache/

# 用户原始资料（体积大/含二进制，本地留存，不入版本控制）
raw/

# Agent 生成产出物（图片等二进制产物，版本化靠文件名而非 git 历史）
outputs/

# 会话导出产物（按需分享，默认不入库）
data_collect/

# wiki 知识内容本地留存，不入版本控制；index.md/log.md（导航+日志）仍追踪
wiki/domains/
wiki/projects/

# Python
__pycache__/
*.pyc
*.pyo

# IDE
.idea/
.vscode/
*.swp
*.swo

# WorkBuddy 项目数据
.workbuddy/
